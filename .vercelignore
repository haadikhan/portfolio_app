# Native / desktop targets (not needed for Flutter web build)
android/
ios/
linux/
macos/
windows/

# Build output and tooling
build/
.dart_tool/
.git/

# Large dependency trees not used by `flutter build web`
**/node_modules/

# Local pub cache (avoids Vercel free-tier file upload limits)
.pub-cache/

# Firebase CLI / Emulator project dir at repo root only (NOT lib/src/core/firebase/)
/firebase/

