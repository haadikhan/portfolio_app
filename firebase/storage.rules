rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Prefer Auth custom claims when present.
    function isAdminToken() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == "admin" ||
        request.auth.token.role == "Admin"
      );
    }

    // Firestore `users/{uid}.role == "admin"` (common when custom claims are not set).
    // Avoid `.lower()` on a missing/non-string field (that denied the whole rule).
    function isAdminFirestoreUserDoc() {
      let path = /databases/(default)/documents/users/$(request.auth.uid);
      return isSignedIn() &&
        firestore.exists(path) &&
        (
          firestore.get(path).data.role == "admin" ||
          firestore.get(path).data.role == "Admin"
        );
    }

    function isAdmin() {
      return isAdminToken() || isAdminFirestoreUserDoc();
    }

    function isCrmFirestoreUserDoc() {
      let path = /databases/(default)/documents/users/$(request.auth.uid);
      return isSignedIn() &&
        firestore.exists(path) &&
        firestore.get(path).data.role == "crm";
    }

    function crmManagesInvestorStorage(investorUid) {
      let ap = /databases/(default)/documents/crm_assignments/$(investorUid);
      return isAdmin() || (
        isCrmFirestoreUserDoc() &&
        firestore.exists(ap) &&
        firestore.get(ap).data.assignedToUid == request.auth.uid
      );
    }

    // Investor-uploaded deposit proof images
    match /deposit_proofs/{userId}/{allPaths=**} {
      // Owner reads their own; any signed-in admin reads all proofs.
      // Any authenticated user can read (admin UI is auth-gated at app level).
      allow read: if isOwner(userId) || isAdmin() || isSignedIn();
      // Only the investor can upload, max 6 MB
      allow write: if isOwner(userId)
        && request.resource.size < 6 * 1024 * 1024;
    }

    // KYC document images (uploaded during KYC flow)
    match /kyc/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin() || isSignedIn();
      allow write: if isOwner(userId)
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Admin-uploaded PDF statements (see Firestore `reports` collection)
    match /reports/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin()
        && request.resource.size < 25 * 1024 * 1024;
    }

    // Admin-uploaded Android APK releases for in-app updates.
    match /releases/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin()
        && request.resource.size < 250 * 1024 * 1024
        && request.resource.contentType == "application/vnd.android.package-archive";
    }

    match /crm_attachments/{investorUid}/{allPaths=**} {
      allow read: if isSignedIn() && crmManagesInvestorStorage(investorUid);
      allow write: if isSignedIn()
        && crmManagesInvestorStorage(investorUid)
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
