rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Custom claims (optional). Firestore `users/{uid}.role` is still the default source of truth.
    function isAdminToken() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == "admin" ||
        request.auth.token.role == "Admin" ||
        request.auth.token.role == "ADMIN"
      );
    }

    // Role checks without .lower() — avoids runtime errors; supports common casings.
    // exists() before get() so missing user docs do not throw inside hasRole.
    function hasRole(role) {
      let p = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn()
        && exists(p)
        && (
          (role == "admin"
            && (get(p).data.role == "admin"
              || get(p).data.role == "Admin"
              || get(p).data.role == "ADMIN"))
          || (role == "crm"
            && (get(p).data.role == "crm"
              || get(p).data.role == "CRM"
              || get(p).data.role == "Crm"))
        );
    }

    function isAdmin() {
      return isAdminToken() || hasRole("admin");
    }

    function isCrm() {
      return hasRole("crm");
    }

    function crmManagesInvestor(investorUid) {
      return isAdmin() || (
        isCrm()
        && exists(/databases/$(database)/documents/crm_assignments/$(investorUid))
        && get(/databases/$(database)/documents/crm_assignments/$(investorUid)).data.assignedToUid == request.auth.uid
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownerUserCreateAllowed() {
      return request.resource.data.keys().hasOnly([
          "email",
          "name",
          "createdAt",
          "kycStatus",
          "phone"
        ])
        && request.resource.data.kycStatus == "pending"
        && !("role" in request.resource.data);
    }

    // FCM transaction may create users/{uid} with only fcmTokens before profile bootstrap runs.
    function ownerFcmTokensCreateOnly() {
      return request.resource.data.keys().hasOnly(["fcmTokens"])
        && request.resource.data.fcmTokens is list
        && request.resource.data.fcmTokens.size() <= 5;
    }

    function ownerUserUpdateAllowed() {
      // Include optional fcmTokens so name/phone updates still validate when tokens exist;
      // tokens may only change via ownerFcmTokensUpdateAllowed().
      // If resource has no email yet (FCM-only doc), allow first-time profile fields from merge.
      return request.resource.data.keys().hasOnly([
          "email",
          "name",
          "createdAt",
          "kycStatus",
          "phone",
          "role",
          "fcmTokens"
        ])
        && (
          (!("email" in resource.data) && request.resource.data.email is string)
          || request.resource.data.email == resource.data.email
        )
        && (
          !("createdAt" in resource.data)
          || request.resource.data.createdAt == resource.data.createdAt
        )
        && (
          !("kycStatus" in resource.data)
          || request.resource.data.kycStatus == resource.data.kycStatus
          || (
            resource.data.kycStatus in ["pending", "rejected"]
            && request.resource.data.kycStatus == "underReview"
          )
        )
        && (
          (!("role" in resource.data) && !("role" in request.resource.data))
          || request.resource.data.role == resource.data.role
        )
        && (
          !("fcmTokens" in resource.data)
            ? !("fcmTokens" in request.resource.data)
            : request.resource.data.fcmTokens == resource.data.fcmTokens
        );
    }

    // Owner-only: merge FCM device tokens (Cloud Functions also write inbox; clients only touch fcmTokens).
    function ownerFcmTokensUpdateAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fcmTokens"]);
    }

    // Investor `kyc/{uid}` submit/resubmit (merge write). Approved docs stay admin-only.
    function investorKycOwnerWriteOk() {
      return request.resource.data.status == "underReview"
        && resource.data.status != "approved"
        && (
          (!("reviewedAt" in resource.data) && !("reviewedAt" in request.resource.data))
          || request.resource.data.reviewedAt == resource.data.reviewedAt
        );
    }

    match /users/{userId} {
      // Own profile: no hasRole()/get() chains — fixes staff login + role stream for admin & CRM.
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow read: if isAdmin() || crmManagesInvestor(userId);
      allow create: if isOwner(userId) && ownerUserCreateAllowed();
      allow create: if isOwner(userId) && ownerFcmTokensCreateOnly();
      allow update: if isOwner(userId) && ownerUserUpdateAllowed();
      allow update: if isOwner(userId) && ownerFcmTokensUpdateAllowed();
      // Staff (admin or CRM assigned to this user) — approve/reject KYC updates `kycStatus` on users/{uid}.
      allow update: if crmManagesInvestor(userId);
      allow delete: if false;

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isAdmin()
          && request.resource.data.keys().hasOnly([
            "title",
            "body",
            "type",
            "read",
            "createdAt",
            "action",
            "refId",
          ])
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 500
          && request.resource.data.body is string
          && request.resource.data.body.size() <= 8000
          && request.resource.data.type == "service_request"
          && request.resource.data.read == false
          && request.resource.data.action == "none"
          && request.resource.data.refId is string
          && request.resource.data.refId.size() <= 200;
        allow delete: if false;
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read", "readAt"]);
      }

      match /consent_events/{eventId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.version is string
          && request.resource.data.source == "in_app_legal";
        allow update, delete: if false;
      }

      match /pendingProfileChanges/{changeId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
          && request.resource.data.status == "pending"
          && request.resource.data.requestedFields is map;
        allow update, delete: if isAdmin();
      }

      // Service-request tickets (investor submits; admin resolves from admin web app).
      // Composite index needed for admin collection-group queries — see codebase comment on AdminChangeRequestService.
      match /changeRequests/{ticketId} {
        allow read: if isOwner(userId) || isAdmin() || crmManagesInvestor(userId);

        function changeRequestInvestorCreateKeysOk() {
          return request.resource.data.keys().hasOnly([
            "requestType",
            "requestedFields",
            "currentFields",
            "status",
            "requestedAt",
            "reviewedAt",
            "reviewNote",
            "reviewedBy",
            "investorName",
            "investorEmail",
          ]);
        }

        // Investor/new doc — must stay pending until staff reviews (serverTimestamp used for requestedAt).
        allow create: if isOwner(userId)
          && changeRequestInvestorCreateKeysOk()
          && request.resource.data.status == "pending"
          && request.resource.data.requestType is string
          && request.resource.data.requestType.size() <= 32
          && request.resource.data.requestedFields is map
          && request.resource.data.requestedFields.size() <= 50
          && request.resource.data.currentFields is map
          && request.resource.data.currentFields.size() <= 50
          && request.resource.data.reviewedAt == null
          && request.resource.data.reviewNote == null
          && request.resource.data.reviewedBy == null;

        function changeRequestApprovedNoteOk() {
          return (
            !("reviewNote" in request.resource.data)
              || request.resource.data.reviewNote == null
              || (
                request.resource.data.reviewNote is string
                && request.resource.data.reviewNote.size() <= 4000
              )
          );
        }

        function changeRequestStaffPatchOk() {
          return resource.data.keys().hasAll([
            "requestType",
            "requestedFields",
            "currentFields",
            "status",
            "requestedAt",
          ])
            && resource.data.status == "pending"
            && (
              request.resource.data.status == "approved"
                || request.resource.data.status == "rejected"
            )
            && request.resource.data.requestType == resource.data.requestType
            && request.resource.data.requestedFields == resource.data.requestedFields
            && request.resource.data.currentFields == resource.data.currentFields
            && request.resource.data.requestedAt == resource.data.requestedAt
            && request.resource.data.reviewedBy is string
            && request.resource.data.reviewedBy.size() > 0
            && request.resource.data.reviewedBy.size() <= 128
            && (
              (
                request.resource.data.status == "approved"
                && changeRequestApprovedNoteOk()
              )
              || (
                request.resource.data.status == "rejected"
                && request.resource.data.reviewNote is string
                && request.resource.data.reviewNote.size() > 0
                && request.resource.data.reviewNote.size() <= 4000
              )
            );
        }

        allow update: if isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "reviewedAt",
          "reviewNote",
          "reviewedBy",
        ]) && changeRequestStaffPatchOk();
        allow delete: if false;
      }

      // Fee statements: server-only writes (Cloud Functions / Admin SDK).
      // Investor reads their own; admin reads all.
      match /fee_statements/{periodKey} {
        allow read: if isOwner(userId) || isAdmin() || crmManagesInvestor(userId);
        allow create, update, delete: if false;
      }

      match /trustedDevices/{deviceHash} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if false;
      }
    }

    // Portfolio value + return history (investor app dashboard; admin applies returns in-app).
    match /portfolios/{portfolioUid} {
      allow read: if isOwner(portfolioUid) || isAdmin() || crmManagesInvestor(portfolioUid);
      allow create, update: if isAdmin();
      allow delete: if false;

      match /returnHistory/{histId} {
        allow read: if isOwner(portfolioUid) || isAdmin() || crmManagesInvestor(portfolioUid);
        allow create, update: if isAdmin();
        allow delete: if false;
      }
    }

    // Primary KYC collection (Wakalat Invest mobile + admin web)
    match /kyc/{userId} {
      allow read: if isOwner(userId) || crmManagesInvestor(userId);
      // Investor creates submission; staff may create if `kyc/{uid}` was missing (merge set == create).
      allow create: if (isOwner(userId) && request.resource.data.status == "underReview")
        || crmManagesInvestor(userId);
      // Investor updates while not approved; staff (admin / assigned CRM) approve or reject.
      allow update: if crmManagesInvestor(userId) || (
        isOwner(userId) && investorKycOwnerWriteOk()
      );
      allow delete: if false;
    }

    match /kyc_profiles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
    }

    // Ledger & wallet: server-only writes (Cloud Functions / Admin SDK)
    match /transactions/{txId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow read: if isCrm() && crmManagesInvestor(resource.data.userId);
      allow create, update, delete: if false;
    }

    match /wallets/{walletId} {
      allow read: if isOwner(walletId) || isAdmin() || crmManagesInvestor(walletId);
      allow create, update, delete: if false;
    }

    match /deposit_requests/{requestId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /withdrawal_requests/{requestId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if hasRole("admin");
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /{document=**} {
        allow read: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    // Admin-published app update metadata consumed by investor app.
    match /app_releases/{releaseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /{document=**} {
        allow read: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    match /market_companies/{companyId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if false;

      match /daily_bars/{barId} {
        allow read: if isSignedIn();
        allow create, update: if isAdmin();
        allow delete: if false;
      }
    }

    // Collection-group read for admin Change Requests screen (collectionGroup("changeRequests")).
    // The nested match /users/{uid}/changeRequests/{ticketId} only covers single-path reads;
    // cross-collection-group queries need this wildcard-path rule.
    match /{path=**}/changeRequests/{ticketId} {
      allow read: if isAdmin();
    }

    // Legacy top-level path — inbox lives under users/{uid}/notifications (server-written).
    match /notifications/{notificationId} {
      allow read, update, create, delete: if false;
    }

    match /consents/{consentId} {
      allow read: if isOwner(consentId) || isAdmin();
      allow create, update: if isOwner(consentId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.accepted == true;
      allow delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if hasRole("admin");
      allow create, update, delete: if false;
    }

    // Company earnings (admin Earnings dashboard). Server-only writes.
    match /company_earnings/{periodKey} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // --- Team CRM ---
    match /crm_assignments/{investorUid} {
      allow read: if isAdmin()
        || (isCrm() && resource.data.assignedToUid == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /crm_notes/{noteId} {
      allow read: if isSignedIn()
        && crmManagesInvestor(resource.data.investorUid);
      allow create: if isSignedIn()
        && crmManagesInvestor(request.resource.data.investorUid)
        && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /crm_followups/{followupId} {
      // CRM dashboard queries by ownerUid + status; rules must allow that shape or
      // Firestore rejects the query (permission-denied) even when documents are valid.
      allow read: if isSignedIn()
        && (
          (isCrm() && resource.data.ownerUid == request.auth.uid)
          || crmManagesInvestor(resource.data.investorUid)
        );
      allow create: if isSignedIn()
        && crmManagesInvestor(request.resource.data.investorUid)
        && (
          isAdmin()
          || (isCrm() && request.resource.data.ownerUid == request.auth.uid)
        );
      allow update: if isAdmin()
        || (
          isCrm()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "completedAt", "rescheduledTo"])
        );
      allow delete: if false;
    }

    match /crm_communications/{commId} {
      allow read: if isSignedIn()
        && crmManagesInvestor(resource.data.investorUid);
      allow create: if isSignedIn()
        && crmManagesInvestor(request.resource.data.investorUid)
        && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Five-market daily feature (Phase 1) ──────────────────────────

    // Admin-editable market config (rates, allocations, benchmarks)
    // Reads existing settings/** admin write access pattern
    match /settings/five_market_calc {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Seeded + admin-managed Pakistan public holidays
    match /settings/pakistan_holidays {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Per-date admin overrides (force close / force open)
    // Investors need to read effective calendar for banner display
    match /settings/five_market/five_market_day_overrides/{dayId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // EOD market close snapshots — server SDK writes only (like transactions)
    match /investment_daily_market_close/{dayId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Per-user daily ledger rows — same access pattern as returnHistory
    match /portfolios/{portfolioUid}/five_market_daily/{dayId} {
      allow read: if isOwner(portfolioUid)
        || isAdmin()
        || crmManagesInvestor(portfolioUid);
      allow write: if false;
    }

    // ── Fee System v2 (Phase 1) ──────────────────────────

    // Referral assignments — admin writes, admin/CRM reads
    match /referrals/{investorUid} {
      allow read: if isAdmin()
        || (isCrm() && resource.data.investorUid == request.auth.uid)
        || isOwner(investorUid);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Company fee ledger — admin read only, server writes
    match /company_fee_ledger/{entryId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Daily management fee subcollection under portfolios
    match /portfolios/{portfolioUid}/management_fee_daily/{dayId} {
      allow read: if isOwner(portfolioUid) || isAdmin();
      allow create, update, delete: if false;
    }

    // investors can read their own feeVersion from users doc
    // (already covered by existing users/{userId} read rule)
    // No new rule needed for users/{uid}.feeVersion field

    // Admin collection-group read for fee audit
    match /{path=**}/management_fee_daily/{dayId} {
      allow read: if isAdmin();
    }

    // ── Fee System v2 — Performance Fee Daily (Phase 4) ─────────

    match /portfolios/{portfolioUid}/performance_fee_daily/{dayId} {
      allow read: if isOwner(portfolioUid) || isAdmin();
      allow create, update, delete: if false;
    }

    match /{path=**}/performance_fee_daily/{dayId} {
      allow read: if isAdmin();
    }
  }
}
